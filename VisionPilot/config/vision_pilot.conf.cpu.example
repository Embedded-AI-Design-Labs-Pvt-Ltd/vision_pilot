# VisionPilot configuration — CPU / Docker Desktop / Raspberry Pi 5
# Copy over vision_pilot.conf or mount this file when engine.provider must be cpu.

source.mode             = video

source.v4l2_device      = /dev/video0
source.v4l2_fps         = 10

engine.provider     = cpu
engine.device_id    = 0
engine.cache_dir    = /tmp/visionpilot_trt_cache
engine.workspace_gb = 1.0

model.precision    = fp32

speed_limit      = 33.3;
Lf               = 2.67

visualization_on = false
webrtc_on = false
webrtc_port = 8080
